---
import MainLayout from '../layouts/MainLayout.astro';
import Button from '../components/Button.astro';

const practices = [
  {
    title: 'Hukum Perdata',
    subtitle: 'Civil Law',
    desc: 'Menangani sengketa perdata secara intensif demi melestarikan hak-hak sipil, kepemilikan aset, dan hubungan kontraktual Anda secara hukum.',
    details: [
      'Sengketa Hak Milik & Agraria (Tanah)',
      'Hukum Waris & Pembagian Harta Bersama',
      'Hukum Keluarga (Perceraian & Hak Asuh)',
      'Gugatan Wanprestasi & Perbuatan Melawan Hukum (PMH)',
      'Pembuatan & Peninjauan Draft Kontrak Perjanjian'
    ],
    iconPath: 'M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z'
  },
  {
    title: 'Hukum Bisnis',
    subtitle: 'Corporate & Commercial Law',
    desc: 'Memberikan perlindungan hukum korporasi sejak pendirian usaha, kepatuhan regulasi, perlindungan modal, hingga transaksi komersial kompleks.',
    details: [
      'Pendirian Badan Usaha (PT, CV, Firma)',
      'Pengurusan Izin Usaha & Kepatuhan Regulasi',
      'Merger, Akuisisi, & Restrukturisasi Perusahaan',
      'Penyusunan Kontrak Bisnis & Kemitraan Dagang',
      'Penyelesaian Sengketa Ketenagakerjaan (Karyawan)'
    ],
    iconPath: 'M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z'
  },
  {
    title: 'Hukum Ekonomi Syariah',
    subtitle: 'Islamic Finance & Syariah Law',
    desc: 'Menghadirkan konsultasi dan advokasi hukum yang selaras dengan prinsip-prinsip syariat Islam untuk kegiatan keuangan dan sosial keagamaan.',
    details: [
      'Sengketa Perbankan & Asuransi Syariah',
      'Penyusunan Kontrak Akad (Mudharabah, Murabahah, dll)',
      'Sengketa Waris & Wasiat Islam',
      'Pengelolaan & Legalitas Wakaf, Hibah, & Zakat',
      'Mediasi Bisnis Syariah Regional'
    ],
    iconPath: 'M12 3v19M5 12h14'
  },
  {
    title: 'Mediasi Sengketa',
    subtitle: 'Alternative Dispute Resolution (ADR)',
    desc: 'Solusi damai alternatif di luar pengadilan yang netral, cepat, efisien, serta menjaga hubungan baik dan reputasi para pihak yang bersengketa.',
    details: [
      'Mediasi Kasus Perdata & Keluarga',
      'Konsiliasi Sengketa Dagang/Komersial',
      'Negosiasi Kontrak Bermasalah',
      'Penyelesaian Hubungan Industrial Damai',
      'Pendampingan Sidang Mediasi Pengadilan'
    ],
    iconPath: 'M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2M23 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75'
  },
  {
    title: 'Konsultasi Hukum Online',
    desc: 'Menghubungkan Anda langsung dengan advokat ahli kami secara aman, rahasia, dan instan via video conference tanpa batas jarak.',
    details: [
      'Konsultasi Tatap Muka Virtual Terenkripsi',
      'Pemeriksaan Berkas Kasus Jarak Jauh',
      'Opini Hukum (Legal Opinion) Tertulis',
      'Akses Fleksibel via Desktop & Smartphone',
      'Solusi Efisien untuk Situasi Mendesak'
    ],
    iconPath: 'M15 10l5 5-5 5M4 4h7a4 4 0 0 1 4 4v12a4 4 0 0 1-4 4H4a4 4 0 0 1-4-4V8a4 4 0 0 1 4-4z'
  }
];
---

<MainLayout title="Bidang Hukum | Amanah Law Firm" description="Lihat ragam bidang hukum spesialisasi kami, mulai dari Hukum Perdata, Hukum Bisnis, Hukum Ekonomi Syariah, Mediasi Sengketa, hingga Konsultasi Hukum Online.">
  <!-- Page Header -->
  <section class="page-header">
    <div class="header-overlay"></div>
    <div class="container header-content">
      <span class="header-tag">Layanan Hukum</span>
      <h1 class="header-title">Bidang Hukum Spesialisasi Kami</h1>
      <p class="header-subtitle">Komitmen kami untuk memberikan bantuan hukum yang komprehensif, strategis, dan tepercaya di berbagai ranah hukum.</p>
    </div>
  </section>

  <!-- Detailed Practice Areas Grid -->
  <section class="practices-detail-section section-padding">
    <div class="container practice-detail-stack">
      {practices.map((practice, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class={`practice-detail-item ${isEven ? 'even' : 'odd'}`}>
            <div class="practice-media-panel">
              <div class="media-accent-box">
                <span class="media-number">{index + 1}</span>
                <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="media-icon">
                  <path d={practice.iconPath} />
                </svg>
              </div>
              <div class="media-glow-effect"></div>
            </div>
            
            <div class="practice-text-panel">
              <h2 class="detail-title">
                {practice.title}
                {practice.subtitle && <span class="detail-subtitle">{practice.subtitle}</span>}
              </h2>
              <p class="detail-desc">{practice.desc}</p>
              
              <div class="detail-bullets-block">
                <h4 class="bullets-heading">Fokus Pelayanan Kami:</h4>
                <ul class="bullets-list">
                  {practice.details.map(bullet => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </div>
              
              <div class="detail-action">
                <Button href="/contact/" variant="secondary">Hubungi Spesialis {practice.title}</Button>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- Working Flow Section -->
  <section class="flow-section section-padding">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Alur Kerja</span>
        <h2 class="section-title">Bagaimana Kami Membantu Anda</h2>
        <p class="section-subtitle">Prosedur penanganan hukum yang sistematis, transparan, dan berorientasi pada ketenangan Anda.</p>
      </div>

      <div class="flow-grid">
        <div class="flow-card">
          <div class="flow-number">1</div>
          <h3 class="flow-title">Konsultasi Awal</h3>
          <p class="flow-text">Diskusikan kronologi dan berkas kasus Anda secara detail bersama advokat kami untuk pemetaan awal.</p>
        </div>

        <div class="flow-card">
          <div class="flow-number">2</div>
          <h3 class="flow-title">Analisis Hukum</h3>
          <p class="flow-text">Tim kami merumuskan opini hukum (legal opinion), opsi penyelesaian, dan strategi langkah hukum terbaik.</p>
        </div>

        <div class="flow-card">
          <div class="flow-number">3</div>
          <h3 class="flow-title">Eksekusi & Advokasi</h3>
          <p class="flow-text">Pendampingan penuh baik melalui jalur mediasi di luar pengadilan maupun litigasi di dalam pengadilan.</p>
        </div>

        <div class="flow-card">
          <div class="flow-number">4</div>
          <h3 class="flow-title">Penyelesaian Kasus</h3>
          <p class="flow-text">Menuntaskan proses hukum dengan laporan berkala, transparan, serta mengamankan hak hukum Anda secara final.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="practices-cta">
    <div class="container practices-cta-container">
      <h2 class="practices-cta-title">Hadapi Masalah Hukum Bersama Kami</h2>
      <p class="practices-cta-desc">Kami siap memberikan pendampingan hukum secara tegas, bermoral, dan amanah. Hubungi kami untuk berkonsultasi.</p>
      <Button href="/contact/" variant="primary">Mulai Konsultasi Hukum</Button>
    </div>
  </section>
</MainLayout>

<style>
  /* Page Header */
  .page-header {
    position: relative;
    background-color: var(--color-primary-dark);
    color: #ffffff;
    padding: 6rem 0;
    text-align: center;
    overflow: hidden;
  }

  .header-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 50%, rgba(109, 40, 217, 0.15) 0%, transparent 80%);
    z-index: 1;
  }

  .header-content {
    position: relative;
    z-index: 2;
    max-width: 750px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .header-tag {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-light);
  }

  .header-title {
    font-size: 2.75rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .header-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-light);
    opacity: 0.85;
    line-height: 1.6;
  }

  /* Practices Detail Stack */
  .practices-detail-section {
    background: var(--color-bg-card);
  }

  .practice-detail-stack {
    display: flex;
    flex-direction: column;
    gap: 7rem;
  }

  .practice-detail-item {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  .practice-detail-item.odd {
    direction: rtl; /* Flip grid visual */
  }

  .practice-detail-item.odd .practice-text-panel {
    direction: ltr; /* Reset text direction to left-to-right */
  }

  /* Media panel details */
  .practice-media-panel {
    position: relative;
    aspect-ratio: 1.2 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .media-accent-box {
    position: relative;
    width: 75%;
    height: 75%;
    border-radius: var(--radius-lg);
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #ffffff;
    box-shadow: var(--shadow-colored);
    border: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 2;
    transition: var(--transition-smooth);
  }

  .practice-detail-item:hover .media-accent-box {
    transform: translateY(-8px) rotate(-2deg);
    box-shadow: var(--shadow-colored-hover);
  }

  .media-number {
    position: absolute;
    top: 1.5rem;
    left: 2rem;
    font-size: 4rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.12);
    line-height: 1;
    font-family: var(--font-sans);
    user-select: none;
  }

  .media-icon {
    width: 4rem;
    height: 4rem;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.15));
  }

  .media-glow-effect {
    position: absolute;
    width: 250px;
    height: 250px;
    background: radial-gradient(circle, rgba(109, 40, 217, 0.2) 0%, transparent 60%);
    filter: blur(15px);
    z-index: 1;
  }

  /* Text panel details */
  .practice-text-panel {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .detail-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
    line-height: 1.15;
  }

  .detail-subtitle {
    display: block;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    margin-top: 0.25rem;
  }

  .detail-desc {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .bullets-heading {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
  }

  .bullets-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
  }

  .bullets-list li {
    position: relative;
    padding-left: 1.5rem;
    font-size: 0.95rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .bullets-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.5rem;
    width: 6px;
    height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
  }

  .detail-action {
    margin-top: 0.5rem;
  }

  /* Flow Section */
  .flow-section {
    background-color: var(--color-bg-light);
  }

  .section-header {
    text-align: center;
    max-width: 650px;
    margin: 0 auto 4rem;
  }

  .section-tag {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .section-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
  }

  .flow-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
  }

  .flow-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 2.5rem 2rem;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: var(--transition-smooth);
  }

  .flow-card:hover {
    transform: translateY(-5px);
    border-color: rgba(109, 40, 217, 0.15);
    box-shadow: var(--shadow-medium);
  }

  .flow-number {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(109, 40, 217, 0.08);
    color: var(--color-accent);
    font-weight: 800;
    font-size: 1.15rem;
  }

  .flow-card:hover .flow-number {
    background: var(--gradient-primary);
    color: #ffffff;
  }

  .flow-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
  }

  .flow-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  /* Practices CTA */
  .practices-cta {
    background-color: var(--color-primary-dark);
    color: #ffffff;
    text-align: center;
    padding: 5rem 0;
  }

  .practices-cta-container {
    max-width: 650px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .practices-cta-title {
    color: #ffffff;
    font-size: 2rem;
    font-weight: 800;
  }

  .practices-cta-desc {
    color: var(--color-text-light);
    opacity: 0.85;
    font-size: 1.05rem;
    line-height: 1.6;
    margin-bottom: 0.5rem;
  }

  /* Responsive Styling */
  @media (max-width: 1024px) {
    .practice-detail-item {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    
    .practice-detail-item.odd {
      direction: ltr; /* Reset alternate layout for smaller screens */
    }
    
    .flow-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .header-title {
      font-size: 2.25rem;
    }
    
    .detail-title {
      font-size: 1.85rem;
    }
    
    .flow-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
