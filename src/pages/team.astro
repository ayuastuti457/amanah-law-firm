---
import MainLayout from '../layouts/MainLayout.astro';
import LawyerCard from '../components/LawyerCard.astro';
import Button from '../components/Button.astro';

const lawyers = [
  { 
    name: 'Ayu Astuti, S.H.', 
    role: 'Pendiri & Partner Utama', 
    specialties: ['Hukum Perdata', 'Hukum Bisnis'],
    desc: 'Memiliki pengalaman lebih dari 10 tahun mendampingi perselisihan perdata korporasi maupun penyusunan legalitas bisnis berskala besar.'
  },
  { 
    name: 'Cilsyla Ayu, S.H.', 
    role: 'Partner Kemitraan', 
    specialties: ['Mediasi Sengketa', 'Hukum Keluarga'],
    desc: 'Ahli dalam penyelesaian sengketa alternatif di luar pengadilan. Memiliki rekam jejak mediasi damai yang luar biasa.'
  },
  { 
    name: 'M. Azka, S.H.', 
    role: 'Spesialis Hukum Pidana', 
    specialties: ['Hukum Pidana', 'Litigasi'],
    desc: 'Berpengalaman mendampingi klien dalam perkara pidana korporasi maupun pidana umum di seluruh pengadilan negeri Jawa Barat.'
  },
  { 
    name: 'M. Hafidz Rashinul F., S.H.', 
    role: 'Partner Korporat', 
    specialties: ['Hukum Bisnis', 'Ekonomi Syariah'],
    desc: 'Ahli hukum perbankan syariah dan restrukturisasi modal perusahaan. Membantu UMKM hingga korporasi multinasional.'
  },
  { 
    name: 'M. Syafiq, S.H.', 
    role: 'Konsultan Hukum Utama', 
    specialties: ['Konsultasi Online', 'Kontrak Bisnis'],
    desc: 'Spesialis konsultasi hukum online dan penyusunan kontrak digital (e-contract). Menjembatani klien dengan solusi legal yang efisien.'
  },
  { 
    name: 'Muzadi Khoirul A., S.H.', 
    role: 'Ahli Mediasi Agraria', 
    specialties: ['Mediasi Sengketa', 'Hukum Agraria'],
    desc: 'Menangani berbagai kasus perselisihan tanah waris, tumpang tindih sertifikat, dan negosiasi pembebasan lahan proyek strategis.'
  },
  { 
    name: 'Nayla Dwi S., S.H.', 
    role: 'Partner Hukum Perdata', 
    specialties: ['Hukum Perdata', 'Hukum Perjanjian'],
    desc: 'Fokus pada penyusunan kontrak niaga, perjanjian pra-nikah, dan penanganan klaim wanprestasi secara akurat.'
  },
  { 
    name: 'Qurrotul Aini, S.H.', 
    role: 'Spesialis Hukum Syariah', 
    specialties: ['Hukum Ekonomi Syariah', 'Waris & Hibah'],
    desc: 'Ahli hukum waris Islam dan hibah. Berpengalaman menyelesaikan pembagian waris secara kekeluargaan maupun via Pengadilan Agama.'
  },
  { 
    name: 'Rizki Maulana, S.H.', 
    role: 'Partner Litigasi Tata Usaha Negara', 
    specialties: ['Litigasi Perdata', 'Hukum Tata Usaha Negara'],
    desc: 'Mewakili individu maupun korporasi dalam gugatan keputusan pejabat publik di Pengadilan Tata Usaha Negara (PTUN).'
  }
];
---

<MainLayout title="Tim Pengacara Kami | Amanah Law Firm" description="Kenali profil 9 advokat profesional dan berintegritas tinggi di Amanah Law Firm yang siap mendampingi urusan hukum Anda.">
  <!-- Page Header -->
  <section class="page-header">
    <div class="header-overlay"></div>
    <div class="container header-content">
      <span class="header-tag">Tim Advokat</span>
      <h1 class="header-title">Profil Tim Pengacara Kami</h1>
      <p class="header-subtitle">Para profesional hukum berdedikasi tinggi yang siap membela kepentingan dan memegang amanah penyelesaian kasus Anda.</p>
    </div>
  </section>

  <!-- Team Grid Section -->
  <section class="team-grid-section section-padding">
    <div class="container">
      <div class="team-grid">
        {lawyers.map((lawyer) => (
          <div class="team-card-wrapper">
            <LawyerCard 
              name={lawyer.name} 
              role={lawyer.role} 
              specialties={lawyer.specialties}
            />
            <div class="lawyer-description">
              <p>{lawyer.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Firm Ethos Callout -->
  <section class="ethos-section section-padding">
    <div class="container ethos-container">
      <div class="ethos-card hover-lift">
        <div class="ethos-glow"></div>
        <div class="ethos-content">
          <span class="ethos-icon">⚖</span>
          <h3 class="ethos-title">Komitmen Bersama Tim Pengacara</h3>
          <p class="ethos-text">
            Seluruh advokat yang bernaung di bawah **Amanah Law Firm** memiliki izin resmi dari organisasi advokat di Indonesia dan memegang teguh kode etik profesi. Kami bekerja sebagai satu tim yang saling mendukung untuk memastikan setiap aspek dari masalah hukum Anda ditinjau dari berbagai sudut pandang keahlian demi meraih kemenangan yang adil.
          </p>
          <div class="ethos-action">
            <Button href="/contact/" variant="primary">Diskusikan Kasus Anda dengan Tim</Button>
          </div>
        </div>
      </div>
    </div>
  </section>
</MainLayout>

<style>
  /* Page Header */
  .page-header {
    position: relative;
    background-color: var(--color-primary-dark);
    color: #ffffff;
    padding: 6rem 0;
    text-align: center;
    overflow: hidden;
  }

  .header-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at 50% 50%, rgba(109, 40, 217, 0.15) 0%, transparent 80%);
    z-index: 1;
  }

  .header-content {
    position: relative;
    z-index: 2;
    max-width: 750px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .header-tag {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent-light);
  }

  .header-title {
    font-size: 2.75rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    line-height: 1.2;
  }

  .header-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-light);
    opacity: 0.85;
    line-height: 1.6;
  }

  /* Team Grid */
  .team-grid-section {
    background: var(--color-bg-card);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 3rem 2.5rem;
  }

  .team-card-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .lawyer-description {
    padding: 0 0.5rem;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.6;
    border-left: 2px solid var(--color-border);
    margin-left: 0.5rem;
  }

  /* Ethos Section */
  .ethos-section {
    background-color: var(--color-bg-light);
  }

  .ethos-container {
    max-width: 800px;
  }

  .ethos-card {
    position: relative;
    background: var(--color-primary-dark);
    color: #ffffff;
    border-radius: var(--radius-lg);
    padding: 4rem 3.5rem;
    overflow: hidden;
    box-shadow: var(--shadow-colored);
  }

  .ethos-glow {
    position: absolute;
    bottom: -30%;
    left: -20%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(109, 40, 217, 0.25) 0%, transparent 75%);
    filter: blur(20px);
    z-index: 1;
  }

  .ethos-content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .ethos-icon {
    font-size: 3rem;
    color: var(--color-accent-light);
    margin-bottom: 0.5rem;
  }

  .ethos-title {
    color: #ffffff;
    font-size: 1.75rem;
    font-weight: 800;
  }

  .ethos-text {
    font-size: 1.05rem;
    color: var(--color-text-light);
    opacity: 0.9;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  /* Responsive Styling */
  @media (max-width: 1024px) {
    .team-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .header-title {
      font-size: 2.25rem;
    }
    
    .team-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .ethos-card {
      padding: 3rem 2rem;
    }
    
    .ethos-title {
      font-size: 1.5rem;
    }
    
    .ethos-text {
      font-size: 0.95rem;
    }
  }
</style>
