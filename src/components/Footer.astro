---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <!-- Info Column -->
    <div class="footer-col brand-col">
      <a href="/" class="logo-group">
        <svg class="logo-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
          <path d="M12 8v8"></path>
          <path d="M9 11h6"></path>
        </svg>
        <span class="logo-title">AMANAH <span class="logo-accent">LAW FIRM</span></span>
      </a>
      <p class="footer-desc">
        Berdedikasi untuk memberikan pelayanan hukum terbaik dengan menjunjung tinggi nilai integritas, profesionalitas, dan amanah bagi seluruh klien kami.
      </p>
      <div class="social-links">
        <a href="#" aria-label="LinkedIn" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
        <a href="#" aria-label="Instagram" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
        <a href="#" aria-label="Twitter" class="social-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </a>
      </div>
    </div>

    <!-- Quick Links -->
    <div class="footer-col links-col">
      <h3 class="footer-heading">Tautan Pintas</h3>
      <ul class="footer-links">
        <li><a href="/">Beranda</a></li>
        <li><a href="/about/">Tentang Kami</a></li>
        <li><a href="/practice-areas/">Bidang Hukum</a></li>
        <li><a href="/team/">Tim Pengacara</a></li>
        <li><a href="/contact/">Kontak</a></li>
      </ul>
    </div>

    <!-- Practice Areas Summary -->
    <div class="footer-col links-col">
      <h3 class="footer-heading">Layanan Hukum</h3>
      <ul class="footer-links">
        <li><a href="/practice-areas/">Hukum Perdata</a></li>
        <li><a href="/practice-areas/">Hukum Bisnis</a></li>
        <li><a href="/practice-areas/">Hukum Ekonomi Syariah</a></li>
        <li><a href="/practice-areas/">Mediasi Sengketa</a></li>
        <li><a href="/practice-areas/">Konsultasi Hukum Online</a></li>
      </ul>
    </div>

    <!-- Contact Info -->
    <div class="footer-col contact-col">
      <h3 class="footer-heading">Hubungi Kami</h3>
      <ul class="contact-details">
        <li class="contact-item">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          <span>Amanah Law Center, Bandung Lantai 3, Jl. A.H Nasution No 105, Cibiru, Bandung</span>
        </li>
        <li class="contact-item">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
          </svg>
          <span>+62 22 1234 5678</span>
        </li>
        <li class="contact-item">
          <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          <span>info@amanahlawfirm.com</span>
        </li>
      </ul>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer-bottom">
    <div class="container bottom-container">
      <p>&copy; {currentYear} Amanah Law Firm. Hak Cipta Dilindungi.</p>
      <div class="bottom-links">
        <a href="#">Kebijakan Privasi</a>
        <a href="#">Syarat & Ketentuan</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-primary-dark);
    color: var(--color-text-light);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: auto;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.5fr;
    gap: 4rem;
    padding-top: 5rem;
    padding-bottom: 4rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Brand Column */
  .brand-col .logo-group {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #ffffff;
  }

  .logo-icon {
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-accent-light);
    filter: drop-shadow(0 2px 8px rgba(109, 40, 217, 0.4));
  }

  .logo-title {
    font-size: 1.25rem;
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .logo-accent {
    font-weight: 400;
    font-size: 1rem;
    opacity: 0.8;
  }

  .footer-desc {
    color: var(--color-text-light);
    opacity: 0.7;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-light);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: var(--transition-smooth);
  }

  .social-icon:hover {
    background: var(--gradient-accent);
    color: #ffffff;
    border-color: transparent;
    transform: translateY(-3px);
  }

  /* Link Columns */
  .footer-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
    position: relative;
    padding-bottom: 0.75rem;
  }

  .footer-heading::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 2rem;
    height: 2px;
    background: var(--color-accent-light);
    border-radius: 1px;
  }

  .footer-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-links a {
    color: var(--color-text-light);
    opacity: 0.75;
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    opacity: 1;
    color: var(--color-accent-light);
    padding-left: 4px;
  }

  /* Contact Column */
  .contact-details {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    gap: 0.75rem;
    font-size: 0.95rem;
    line-height: 1.5;
    opacity: 0.75;
  }

  .contact-icon {
    flex-shrink: 0;
    width: 1.25rem;
    height: 1.25rem;
    color: var(--color-accent-light);
    margin-top: 0.15rem;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding: 2rem 0;
    font-size: 0.9rem;
    opacity: 0.6;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .bottom-links {
    display: flex;
    gap: 1.5rem;
  }

  .bottom-links a:hover {
    color: var(--color-accent-light);
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding-top: 3.5rem;
    }
    
    .bottom-container {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }
  }
</style>
