---
interface Props {
  name: string;
  role?: string;
  specialties?: string[];
  image?: string;
}

const { 
  name, 
  role = 'Partner Hukum', 
  specialties = ['Hukum Perdata', 'Hukum Bisnis'], 
  image 
} = Astro.props;

// Generate initials for the avatar placeholder
const initials = name
  .split(' ')
  .filter(word => !word.includes('.')) // Skip S.H., M.H., etc.
  .map(word => word[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<div class="lawyer-card">
  <div class="image-container">
    {image ? (
      <img src={image} alt={name} class="lawyer-image" />
    ) : (
      <div class="avatar-placeholder">
        <div class="avatar-glow"></div>
        <span class="avatar-text">{initials}</span>
        <div class="decor-line"></div>
      </div>
    )}
    <div class="card-overlay">
      <div class="specialties-tags">
        {specialties.map(spec => (
          <span class="spec-tag">{spec}</span>
        ))}
      </div>
    </div>
  </div>
  
  <div class="info-section">
    <h3 class="lawyer-name">{name}</h3>
    <p class="lawyer-role">{role}</p>
    
    <div class="card-footer-decor">
      <span class="law-scale-symbol">⚖</span>
      <span class="decor-dot"></span>
      <span class="decor-text">Amanah Law Firm</span>
    </div>
  </div>
</div>

<style>
  .lawyer-card {
    background: var(--color-bg-card);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(226, 232, 240, 0.8);
    box-shadow: var(--shadow-subtle);
    overflow: hidden;
    transition: var(--transition-smooth);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .lawyer-card:hover {
    transform: translateY(-6px);
    border-color: rgba(109, 40, 217, 0.2);
    box-shadow: var(--shadow-colored);
  }

  /* Image Container & Avatar styling */
  .image-container {
    position: relative;
    aspect-ratio: 4 / 5;
    width: 100%;
    background: #0f172a; /* Slate 900 background */
    overflow: hidden;
  }

  .lawyer-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .lawyer-card:hover .lawyer-image {
    transform: scale(1.05);
  }

  /* Premium placeholder styles when image is absent */
  .avatar-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1e1b4b 0%, #0f172a 100%);
    position: relative;
  }

  .avatar-glow {
    position: absolute;
    width: 70%;
    height: 70%;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(109, 40, 217, 0.3) 0%, rgba(109, 40, 217, 0) 70%);
    filter: blur(10px);
    transition: var(--transition-smooth);
  }

  .lawyer-card:hover .avatar-glow {
    background: radial-gradient(circle, rgba(139, 92, 246, 0.45) 0%, rgba(109, 40, 217, 0) 75%);
    transform: scale(1.1);
  }

  .avatar-text {
    font-size: 3.5rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.85);
    z-index: 2;
    letter-spacing: 0.05em;
    font-family: var(--font-sans);
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.3);
    transition: var(--transition-smooth);
  }

  .lawyer-card:hover .avatar-text {
    color: #ffffff;
    transform: scale(1.05);
  }

  .decor-line {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    width: 3rem;
    height: 2px;
    background: var(--gradient-accent);
    border-radius: 1px;
    opacity: 0.6;
    transition: var(--transition-smooth);
  }

  .lawyer-card:hover .decor-line {
    width: 5rem;
    opacity: 1;
  }

  /* Overlay and Specialties tags */
  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    background: linear-gradient(to top, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0) 100%);
    z-index: 3;
    opacity: 0.9;
    transition: var(--transition-smooth);
  }

  .specialties-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .spec-tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.25rem 0.65rem;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.1);
    color: #ffffff;
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  /* Info Section */
  .info-section {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .lawyer-name {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }

  .lawyer-role {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-accent);
    margin-bottom: 1.25rem;
  }

  /* Card Decor Footer */
  .card-footer-decor {
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(226, 232, 240, 0.6);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    opacity: 0.8;
  }

  .law-scale-symbol {
    font-size: 0.95rem;
    color: var(--color-accent);
  }

  .decor-dot {
    width: 3px;
    height: 3px;
    background-color: var(--color-border-hover);
    border-radius: 50%;
  }

  .decor-text {
    font-weight: 500;
    letter-spacing: 0.05em;
  }
</style>
